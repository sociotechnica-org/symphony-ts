#!/usr/bin/env bash
set -euo pipefail

if [[ "$1" == "pr" && "$2" == "create" ]]; then
  shift 2
  TITLE=""
  BODY=""
  BASE="main"
  HEAD=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --title)
        TITLE="$2"
        shift 2
        ;;
      --body)
        BODY="$2"
        shift 2
        ;;
      --base)
        BASE="$2"
        shift 2
        ;;
      --head)
        HEAD="$2"
        shift 2
        ;;
      *)
        shift
        ;;
    esac
  done
  JSON_PAYLOAD="$(
    TITLE="$TITLE" BODY="$BODY" HEAD="$HEAD" BASE="$BASE" \
      node -e 'process.stdout.write(JSON.stringify({ title: process.env.TITLE, body: process.env.BODY, head: process.env.HEAD, base: process.env.BASE }))'
  )"
  curl -sS -X POST "${MOCK_GITHUB_API_URL}/mock/prs" \
    -H 'content-type: application/json' \
    -d "$JSON_PAYLOAD" >/dev/null
  echo "https://example.test/pr/1"
  exit 0
fi

if [[ "$1" == "auth" && "$2" == "token" ]]; then
  printf '%s\n' "${GH_TOKEN:-test-token}"
  exit 0
fi

echo "mock-gh: unsupported command $*" >&2
exit 1
